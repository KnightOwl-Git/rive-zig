// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
//
// Example:
[
  {
    "label": "build",
    "command": "zig build",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "show_summary": true,
    "show_command": true,
  },

  {
    "label": "run",
    "command": "zig build run",
    "env": { "foo": "bar" },
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "show_summary": true,
    "show_command": true,
  },
]
